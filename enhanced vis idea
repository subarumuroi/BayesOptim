
import numpy as np
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA

# Example high-dimensional experiment matrix
X = np.random.rand(30, 6)  # 30 experiments, 6 variables
y = np.sin(X[:,0]*5) + np.cos(X[:,1]*4)

# PCA projection
pca = PCA(n_components=2)
X_proj = pca.fit_transform(X)

plt.figure(figsize=(6,5))

sc = plt.scatter(
    X_proj[:,0],
    X_proj[:,1],
    c=y,
    s=80
)

plt.plot(X_proj[:,0], X_proj[:,1], alpha=0.4)

plt.xlabel("PC1")
plt.ylabel("PC2")
plt.title("Bayesian Optimization Search Trajectory")

plt.colorbar(sc,label="Measured Response")

plt.show()



